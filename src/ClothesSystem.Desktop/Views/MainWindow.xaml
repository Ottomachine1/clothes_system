<Window x:Class="ClothesSystem.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ClothesSystem.Desktop.ViewModels"
        Title="服装款式管理系统"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Navigation Panel -->
        <Border Grid.Column="0" Background="#2D2D30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="15,20,15,30">
                    <TextBlock Text="服装管理系统"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{Binding CurrentUserName}"
                               FontSize="12"
                               Foreground="#AAAAAA"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Navigation Menu -->
                <StackPanel Grid.Row="1" Margin="10,0">
                    <Button Content="首页/仪表盘"
                            Style="{StaticResource NavButton}"
                            Command="{Binding NavigateHomeCommand}"/>
                    <Button Content="款式列表"
                            Style="{StaticResource NavButton}"
                            Command="{Binding NavigateClothingListCommand}"/>
                    <Button Content="新建款式"
                            Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCreateCommand}"/>
                    <Button Content="管理员面板"
                            Style="{StaticResource NavButton}"
                            Command="{Binding NavigateAdminCommand}"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <!-- Logout -->
                <StackPanel Grid.Row="2" Margin="10,0,10,20">
                    <Separator Background="#555555" Margin="0,0,0,15"/>
                    <Button Content="退出登录"
                            Style="{StaticResource NavButton}"
                            Command="{Binding LogoutCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Frame Grid.Column="1"
               x:Name="ContentFrame"
               NavigationUIVisibility="Hidden"
               Background="{StaticResource BackgroundBrush}"/>
    </Grid>
</Window>
