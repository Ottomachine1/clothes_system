<Page x:Class="ClothesSystem.Desktop.Views.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ClothesSystem.Desktop.ViewModels"
      Title="管理员面板 - 服装管理系统">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="管理员面板"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="系统数据概览"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Content -->
        <Grid Grid.Row="1" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Summary Cards -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="25" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="总款式数" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Summary.VisibleItemsCount}"
                                   FontSize="36" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="25" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="我的款式" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Summary.MyItemsCount}"
                                   FontSize="36" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="25" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="进行中" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Summary.ActiveItemsCount}"
                                   FontSize="36" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="White" CornerRadius="8" Padding="25">
                    <StackPanel>
                        <TextBlock Text="已完成" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Summary.CompletedItemsCount}"
                                   FontSize="36" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Owner Summary -->
            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="25">
                <StackPanel>
                    <TextBlock Text="各负责人款式统计" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <DataGrid ItemsSource="{Binding Summary.OwnerSummaries}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="负责人" Binding="{Binding OwnerDisplayName}" Width="*"/>
                            <DataGridTextColumn Header="款式数" Binding="{Binding ItemCount}" Width="120"/>
                            <DataGridTextColumn Header="进行中" Binding="{Binding ActiveCount}" Width="120"/>
                            <DataGridTextColumn Header="已完成" Binding="{Binding CompletedCount}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Loading -->
        <StackPanel Grid.Row="0" Grid.RowSpan="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <ProgressBar IsIndeterminate="True" Width="200" Height="6"/>
            <TextBlock Text="加载中..." Margin="0,15,0,0"/>
        </StackPanel>
    </Grid>
</Page>
