<Page x:Class="ClothesSystem.Desktop.Views.ClothingEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ClothesSystem.Desktop.ViewModels"
      Title="编辑款式 - 服装管理系统">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="编辑款式"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNewItem}" Value="True">
                                    <Setter Property="Text" Value="新建款式"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding StyleNumber}"
                           FontSize="16"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="取消"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding CancelCommand}"/>
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Main Form -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <!-- Basic Info -->
                    <Border Background="White" CornerRadius="8" Padding="25" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="基本信息" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="款号:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding StyleNumber}" IsEnabled="False" Background="#F5F5F5"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="名称:" VerticalAlignment="Center" Margin="0,15,0,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,15,0,0"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="年份:" VerticalAlignment="Center" Margin="0,15,0,0"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Year}" Margin="0,15,0,0" Width="100" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="季节:" VerticalAlignment="Center" Margin="0,15,0,0"/>
                                <ComboBox Grid.Row="3" Grid.Column="1" Text="{Binding Season}" Margin="0,15,0,0" Width="150" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="春"/>
                                    <ComboBoxItem Content="夏"/>
                                    <ComboBoxItem Content="秋"/>
                                    <ComboBoxItem Content="冬"/>
                                    <ComboBoxItem Content="SS"/>
                                    <ComboBoxItem Content="AW"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Fabric Information -->
                    <Border Background="White" CornerRadius="8" Padding="25" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="面料信息" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>

                            <ItemsControl ItemsSource="{Binding FabricEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBox Text="{Binding MaterialName, UpdateSourceTrigger=PropertyChanged}"
                                                         Tag="面料名称"
                                                         Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding Specification, UpdateSourceTrigger=PropertyChanged}"
                                                         Tag="规格"
                                                         Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding Remark, UpdateSourceTrigger=PropertyChanged}"
                                                         Tag="备注"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="删除"
                                                    Style="{StaticResource DangerButton}"
                                                    Padding="10,5"
                                                    Command="{Binding DataContext.RemoveFabricCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    VerticalAlignment="Top"
                                                    Margin="10,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Content="添加面料"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding AddFabricCommand}"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Description -->
                    <Border Background="White" CornerRadius="8" Padding="25">
                        <StackPanel>
                            <TextBlock Text="款式说明" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Height="150"
                                     VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Image Section -->
                <StackPanel Grid.Column="1">
                    <!-- Existing Images -->
                    <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="现有图片" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>
                            <ItemsControl ItemsSource="{Binding ExistingImages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10">
                                            <StackPanel>
                                                <Image Source="{Binding BinaryContent, Converter={StaticResource ByteArrayToImage}}"
                                                       MaxHeight="120"
                                                       Stretch="Uniform"/>
                                                <TextBlock Text="{Binding OriginalFileName}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,5,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- New Images -->
                    <Border Background="White" CornerRadius="8" Padding="20">
                        <StackPanel>
                            <TextBlock Text="添加新图片" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>

                            <Button Content="选择图片"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding AddImagesCommand}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,10"/>

                            <ItemsControl ItemsSource="{Binding NewImages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10" BorderBrush="#E1E1E1" BorderThickness="1" Padding="10" CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding ContentType}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Content="X"
                                                        Style="{StaticResource DangerButton}"
                                                        Padding="8,4"
                                                        Command="{Binding DataContext.RemoveNewImageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="图片限制: JPG, PNG, WEBP 格式，最大 5MB"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" Padding="25" Margin="0,20,0,0" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="取消"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding CancelCommand}"
                            Margin="0,0,10,0"/>
                    <Button Content="保存"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveCommand}"
                            IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBool}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80FFFFFF"
                Visibility="{Binding IsSaving, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="150" Height="6"/>
                <TextBlock Text="保存中..." Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
