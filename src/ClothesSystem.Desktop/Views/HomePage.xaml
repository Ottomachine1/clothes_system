<Page x:Class="ClothesSystem.Desktop.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ClothesSystem.Desktop.ViewModels"
      Title="首页 - 服装管理系统">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="仪表盘"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="欢迎使用服装款式管理系统"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Dashboard Cards -->
        <Grid Grid.Row="1" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Items Card -->
            <Border Grid.Row="0" Grid.Column="0"
                    Background="White"
                    CornerRadius="8"
                    Margin="0,0,15,15"
                    Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="总款式数"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding VisibleItemsCount}"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,10,0,0"/>
                    <Button Content="查看所有款式"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding NavigateClothingListCommand}"
                            HorizontalAlignment="Left"
                            Margin="0,20,0,0"/>
                </StackPanel>
            </Border>

            <!-- My Items Card -->
            <Border Grid.Row="0" Grid.Column="1"
                    Background="White"
                    CornerRadius="8"
                    Margin="15,0,0,15"
                    Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="我的款式数"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding MyItemsCount}"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="{StaticResource SecondaryBrush}"
                               Margin="0,10,0,0"/>
                    <Button Content="新建款式"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding NavigateCreateCommand}"
                            HorizontalAlignment="Left"
                            Margin="0,20,0,0"/>
                </StackPanel>
            </Border>

            <!-- Active Items Card -->
            <Border Grid.Row="1" Grid.Column="0"
                    Background="White"
                    CornerRadius="8"
                    Margin="0,15,15,0"
                    Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="进行中"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding ActiveItemsCount}"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="{StaticResource WarningBrush}"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Completed Items Card -->
            <Border Grid.Row="1" Grid.Column="1"
                    Background="White"
                    CornerRadius="8"
                    Margin="15,15,0,0"
                    Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="已完成"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding CompletedItemsCount}"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="{StaticResource SuccessBrush}"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Loading -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <ProgressBar IsIndeterminate="True" Width="200" Height="6"/>
            <TextBlock Text="加载中..."
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,15,0,0"/>
        </StackPanel>
    </Grid>
</Page>
