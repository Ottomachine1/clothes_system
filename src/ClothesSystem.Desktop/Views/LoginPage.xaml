<Page x:Class="ClothesSystem.Desktop.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ClothesSystem.Desktop.ViewModels"
      Title="登录 - 服装管理系统">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Border Background="White"
                CornerRadius="8"
                Padding="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="350">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.2" ShadowDepth="2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="服装管理系统"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="请登录以继续"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <Label Content="用户名"/>
                <TextBox x:Name="UsernameTextBox"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5,0,20"/>

                <Label Content="密码"/>
                <PasswordBox x:Name="PasswordBox"
                             Margin="0,5,0,25"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <Button Content="登录"
                        Style="{StaticResource PrimaryButton}"
                        Click="LoginButton_Click"
                        Height="40"
                        FontSize="16"
                        Margin="0,0,0,15"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           TextAlignment="Center"
                           Margin="0,0,0,10"/>

                <ProgressBar IsIndeterminate="True"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                             Height="4"
                             Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
