<Page x:Class="ClothesSystem.Desktop.Views.ClothingListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ClothesSystem.Desktop.ViewModels"
      Title="款式列表 - 服装管理系统">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="款式列表"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="浏览和管理所有服装款式"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Search Panel -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="款号:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Text="{Binding StyleNumberFilter, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="关键词:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Text="{Binding KeywordFilter, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <Button Content="搜索" Style="{StaticResource PrimaryButton}" Command="{Binding SearchCommand}" Margin="0,0,10,0"/>
                    <Button Content="新建款式" Style="{StaticResource SecondaryButton}" Command="{Binding CreateCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Results DataGrid -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="0">
            <DataGrid ItemsSource="{Binding Items}" Margin="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="款号" Binding="{Binding StyleNumber}" Width="130"/>
                    <DataGridTextColumn Header="名称" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="季节" Binding="{Binding Season}" Width="80"/>
                    <DataGridTextColumn Header="进度" Binding="{Binding ProgressDisplayName}" Width="80"/>
                    <DataGridTextColumn Header="审批" Binding="{Binding ApprovalStatusDisplayName}" Width="90"/>
                    <DataGridTextColumn Header="负责人" Binding="{Binding OwnerDisplayName}" Width="100"/>
                    <DataGridTextColumn Header="更新时间" Binding="{Binding UpdatedAtUtc, StringFormat='yyyy-MM-dd'}" Width="110"/>
                    <DataGridTemplateColumn Header="操作" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="查看"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="10,5"
                                            Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}"/>
                                    <Button Content="编辑"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="10,5"
                                            Margin="5,0,0,0"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="2"
                Background="#80FFFFFF"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="150" Height="6"/>
                <TextBlock Text="加载中..." Margin="0,15,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
