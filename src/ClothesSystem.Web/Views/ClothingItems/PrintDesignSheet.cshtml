@model ClothingItemPrintViewModel
@{
    Layout = null;
    var primarySrc = Model.PrimaryImageBase64 != null
        ? $"data:{Model.PrimaryImageContentType};base64,{Model.PrimaryImageBase64}"
        : (string?)null;
    var secondarySrc = Model.SecondaryImageBase64 != null
        ? $"data:{Model.SecondaryImageContentType};base64,{Model.SecondaryImageBase64}"
        : (string?)null;
    var fabricEntries = Model.Item.FabricEntries.ToList();
    var fabricA = fabricEntries.Count > 0 ? fabricEntries[0] : null;
    var fabricB = fabricEntries.Count > 1 ? fabricEntries[1] : null;
    var fabricC = fabricEntries.Count > 2 ? fabricEntries[2] : null;
    var lining = fabricEntries.Count > 3 ? fabricEntries[3] : null;
    var latestApproval = Model.Item.ApprovalRecords.OrderByDescending(r => r.CreatedAtUtc).FirstOrDefault();
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>设计单 @Model.Item.StyleNumber</title>
    <style>
        @@page {
            size: A4;
            margin: 15mm;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: "Microsoft YaHei", "SimHei", "Arial", sans-serif;
            font-size: 13px;
            color: #111;
            background: #fff;
        }

        .sheet {
            width: 210mm;
            min-height: 276mm;
            padding: 10mm 12mm;
            margin: 0 auto;
            background: #fff;
        }

        /* ===== HEADER ===== */
        .header {
            display: table;
            width: 100%;
            border-collapse: collapse;
            border-bottom: 1.5pt solid #111;
            margin-bottom: 6pt;
        }

        .header-row {
            display: table-row;
        }

        .header-cell {
            display: table-cell;
            padding: 3pt 4pt;
            vertical-align: middle;
            font-size: 12pt;
            font-weight: bold;
        }

        .header-label {
            font-size: 9pt;
            color: #555;
            font-weight: normal;
            display: block;
        }

        .header-cell.title {
            font-size: 16pt;
            letter-spacing: 2pt;
            padding-bottom: 4pt;
        }

        .header-meta {
            display: table;
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 6pt;
        }

        .meta-row {
            display: table-row;
        }

        .meta-cell {
            display: table-cell;
            padding: 2pt 4pt;
            font-size: 10pt;
            width: 25%;
        }

        .meta-cell .label {
            font-size: 8pt;
            color: #666;
            display: block;
        }

        /* ===== MAIN GRID ===== */
        .main-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            grid-template-rows: auto auto;
            gap: 6pt;
            margin-bottom: 6pt;
        }

        .image-panel {
            grid-column: 1;
            grid-row: 1;
            border: 0.75pt solid #aaa;
            padding: 4pt;
            min-height: 120pt;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .image-panel img {
            max-width: 100%;
            max-height: 130pt;
            object-fit: contain;
        }

        .image-panel .placeholder {
            color: #bbb;
            font-size: 10pt;
            text-align: center;
        }

        .notes-panel {
            grid-column: 2;
            grid-row: 1;
            border: 0.75pt solid #aaa;
            padding: 4pt 5pt;
            vertical-align: top;
        }

        .notes-panel h3 {
            font-size: 9pt;
            color: #555;
            margin-bottom: 3pt;
            border-bottom: 0.5pt solid #ddd;
            padding-bottom: 2pt;
        }

        .notes-panel ul {
            list-style: none;
            padding: 0;
        }

        .notes-panel li {
            font-size: 8.5pt;
            line-height: 1.5;
            color: #333;
            padding: 1pt 0;
            border-bottom: 0.25pt solid #f0f0f0;
        }

        .notes-panel li:last-child {
            border-bottom: none;
        }

        /* Secondary image + notes below */
        .secondary-row {
            grid-column: 1 / -1;
            grid-row: 2;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6pt;
        }

        .secondary-image-panel {
            border: 0.75pt solid #aaa;
            padding: 4pt;
            min-height: 80pt;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .secondary-image-panel img {
            max-width: 100%;
            max-height: 80pt;
            object-fit: contain;
        }

        .secondary-image-panel .placeholder {
            color: #bbb;
            font-size: 10pt;
            text-align: center;
        }

        /* ===== PRODUCT NAME ===== */
        .product-name {
            border: 0.75pt solid #aaa;
            padding: 4pt 6pt;
            margin-bottom: 4pt;
            display: table;
            width: 100%;
        }

        .product-name .label {
            font-size: 8pt;
            color: #666;
            display: block;
            margin-bottom: 1pt;
        }

        .product-name .value {
            font-size: 13pt;
            font-weight: bold;
            color: #111;
            letter-spacing: 1pt;
        }

        /* ===== SIZE TABLE ===== */
        .size-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 4pt;
            font-size: 9pt;
        }

        .size-table th,
        .size-table td {
            border: 0.5pt solid #aaa;
            padding: 2pt 4pt;
            text-align: center;
        }

        .size-table th {
            background: #f5f5f5;
            font-weight: bold;
            font-size: 8pt;
        }

        /* ===== FABRIC GRID ===== */
        .fabric-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr 1fr;
            gap: 4pt;
            margin-bottom: 6pt;
        }

        .fabric-card {
            border: 0.75pt solid #aaa;
            padding: 4pt 5pt;
        }

        .fabric-card .fabric-label {
            font-size: 8pt;
            color: #666;
            margin-bottom: 2pt;
            display: block;
        }

        .fabric-card .fabric-name {
            font-size: 9pt;
            font-weight: bold;
            color: #111;
            margin-bottom: 1pt;
        }

        .fabric-card .fabric-spec {
            font-size: 8pt;
            color: #444;
        }

        .fabric-card .fabric-remark {
            font-size: 7.5pt;
            color: #888;
            margin-top: 1pt;
        }

        /* ===== APPROVAL ===== */
        .approval-row {
            border: 0.75pt solid #aaa;
            padding: 4pt 6pt;
            font-size: 9pt;
            display: table;
            width: 100%;
        }

        .approval-row .label {
            font-size: 8pt;
            color: #666;
            display: block;
            margin-bottom: 1pt;
        }

        .approval-row .value {
            font-size: 9pt;
            color: #111;
        }

        /* ===== PRINT OVERRIDES ===== */
        thead { display: table-header-group; }
        tfoot { display: table-footer-group; }

        @@media print {
            body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            .sheet { width: 100%; min-height: auto; padding: 0; }
        }
    </style>
</head>
<body onload="window.print()">

<div class="sheet">

    <!-- HEADER -->
    <div class="header">
        <div class="header-row">
            <div class="header-cell title">
                设计单
                <span class="header-label">DESIGN SHEET</span>
            </div>
        </div>
        <div class="header-row">
            <div class="header-cell">
                <span class="header-label">款号</span>
                @Model.Item.StyleNumber
            </div>
            <div class="header-cell">
                <span class="header-label">季度</span>
                @Model.QuarterDisplay
            </div>
            <div class="header-cell">
                <span class="header-label">设计师</span>
                @Model.Item.OwnerDisplayName
            </div>
        </div>
    </div>

    <!-- META ROW -->
    <div class="header-meta">
        <div class="meta-row">
            <div class="meta-cell">
                <span class="label">下单日期</span>
                @Model.OrderDateDisplay
            </div>
            <div class="meta-cell">
                <span class="label">版师</span>
                &nbsp;
            </div>
            <div class="meta-cell">
                <span class="label">样衣师</span>
                &nbsp;
            </div>
            <div class="meta-cell">
                <span class="label">进度</span>
                @Model.Item.ProgressDisplayName
            </div>
        </div>
    </div>

    <!-- MAIN IMAGE + NOTES GRID -->
    <div class="main-grid">
        <div class="image-panel">
            @if (primarySrc != null)
            {
                <img src="@primarySrc" alt="款式图片" />
            }
            else
            {
                <div class="placeholder">（暂无图片）</div>
            }
        </div>

        <div class="notes-panel">
            <h3>修改意见</h3>
            <ul>
                @foreach (var note in Model.PrimaryImageNotes)
                {
                    <li>@note</li>
                }
            </ul>
        </div>

        @if (secondarySrc != null)
        {
            <div class="secondary-row">
                <div class="secondary-image-panel">
                    <img src="@secondarySrc" alt="第二张图片" />
                </div>
                <div class="notes-panel">
                    <h3>补充说明</h3>
                    <ul>
                        @foreach (var note in Model.SecondaryImageNotes)
                        {
                            <li>@note</li>
                        }
                    </ul>
                </div>
            </div>
        }
    </div>

    <!-- PRODUCT NAME -->
    <div class="product-name">
        <span class="label">品名 / Product Name</span>
        <span class="value">@Model.Item.Title</span>
    </div>

    <!-- FABRIC GRID -->
    <div class="fabric-grid">
        <div class="fabric-card">
            <span class="fabric-label">面料 A</span>
            @if (fabricA != null)
            {
                <div class="fabric-name">@fabricA.MaterialName</div>
                <div class="fabric-spec">@fabricA.Specification</div>
                @if (!string.IsNullOrWhiteSpace(fabricA.Remark))
                {
                    <div class="fabric-remark">@fabricA.Remark</div>
                }
            }
            else
            {
                <div class="fabric-name">&nbsp;</div>
            }
        </div>
        <div class="fabric-card">
            <span class="fabric-label">面料 B</span>
            @if (fabricB != null)
            {
                <div class="fabric-name">@fabricB.MaterialName</div>
                <div class="fabric-spec">@fabricB.Specification</div>
                @if (!string.IsNullOrWhiteSpace(fabricB.Remark))
                {
                    <div class="fabric-remark">@fabricB.Remark</div>
                }
            }
            else
            {
                <div class="fabric-name">&nbsp;</div>
            }
        </div>
        <div class="fabric-card">
            <span class="fabric-label">面料 C</span>
            @if (fabricC != null)
            {
                <div class="fabric-name">@fabricC.MaterialName</div>
                <div class="fabric-spec">@fabricC.Specification</div>
                @if (!string.IsNullOrWhiteSpace(fabricC.Remark))
                {
                    <div class="fabric-remark">@fabricC.Remark</div>
                }
            }
            else
            {
                <div class="fabric-name">&nbsp;</div>
            }
        </div>
        <div class="fabric-card">
            <span class="fabric-label">里料</span>
            @if (lining != null)
            {
                <div class="fabric-name">@lining.MaterialName</div>
                <div class="fabric-spec">@lining.Specification</div>
                @if (!string.IsNullOrWhiteSpace(lining.Remark))
                {
                    <div class="fabric-remark">@lining.Remark</div>
                }
            }
            else
            {
                <div class="fabric-name">&nbsp;</div>
            }
        </div>
    </div>

    <!-- APPROVAL -->
    <div class="approval-row">
        <span class="label">设计总监审批</span>
        <span class="value">
            @Model.Item.ApprovalStatusDisplayName
            @if (latestApproval != null && !string.IsNullOrWhiteSpace(latestApproval.Comment))
            {
                <span> — @latestApproval.Comment</span>
            }
        </span>
    </div>

</div>

</body>
</html>
